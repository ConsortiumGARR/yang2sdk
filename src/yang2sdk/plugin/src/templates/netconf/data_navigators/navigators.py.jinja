{% elif node.node_type == 'rpc' %}
class {{ node.class_name }}Node(Node):
    def __call__(self{% if node.has_input %}, input_data: {{ node.pydantic_module }}.{{ node.class_name }}Input | dict | str | None = None, **kwargs: Any{% endif %}){% if node.has_output %} -> {{ node.pydantic_module }}.{{ node.class_name }}Output | None{% else %} -> None{% endif %}:
        {% if node.has_input or node.has_output %}
        from ..data_models.{{ node.pydantic_module }} import {% if node.has_input %}{{ node.class_name }}Input{% endif %}{% if node.has_input and node.has_output %}, {% endif %}{% if node.has_output %}{{ node.class_name }}Output{% endif %}
        {% endif %}
        ns, tag, _ = self._path[-1]
        rpc_elem = etree.Element("{" + ns + "}" + tag, nsmap={None: ns})
        
        {% if node.has_input %}
        if input_data is None and kwargs: input_data = {k.replace('_', '-'): v for k, v in kwargs.items()}
        if isinstance(input_data, dict): input_data = {{ node.class_name }}Input.model_validate(input_data)
        elif isinstance(input_data, str): input_data = {{ node.class_name }}Input.from_xml(input_data) if input_data.strip().startswith('<') else {{ node.class_name }}Input.model_validate_json(input_data)
        if input_data:
            for child in etree.fromstring(input_data.to_xml_payload()): rpc_elem.append(child)
        {% endif %}
        
        resp_elem = self._client.rpc(rpc_elem)
        
        {% if node.has_output %}
        if resp_elem is not None and len(resp_elem) > 0:
            return {{ node.class_name }}Output.from_xml(etree.tostring(resp_elem))
        return None
        {% endif %}
{% endif %}
