{% if node.node_type == 'container' %}
class {{ node.class_name }}Node(ItemNode):
    def retrieve(self, *, source: str = 'running', content: str = 'all', with_defaults: str = 'report-all', depth: int | str = 2, fields: list[str] | None = None) -> {{ node.pydantic_module }}.{{ node.class_name }} | None:
        from ..data_models.{{ node.pydantic_module }} import {{ node.class_name }}
        xml_filter = build_filter_tree(self._path, {{ node.class_name }}, content=content, depth=depth, fields=fields)
        xml_data = self._client.get_config(source=source, filter_xml=xml_filter, with_defaults=with_defaults) if content == 'config' else self._client.get(filter_xml=xml_filter, with_defaults=with_defaults)
        matched = find_xml_node(xml_data, self._path)
        if matched is not None:
            if isinstance(depth, int) or (isinstance(depth, str) and depth.isdigit()): prune_xml_tree_to_depth(matched, {{ node.class_name }}, int(depth))
            return {{ node.class_name }}.from_xml(etree.tostring(matched))
        return None

    def update(self, data: {{ node.pydantic_module }}.{{ node.class_name }} | dict | str | None = None, *, target: str = 'candidate', operation: str = 'merge', **kwargs: Any) -> bool:
        from ..data_models.{{ node.pydantic_module }} import {{ node.class_name }}
        if data is None and kwargs: data = {k.replace('_', '-'): v for k, v in kwargs.items()}
        if isinstance(data, dict): data = {{ node.class_name }}.model_validate(data)
        elif isinstance(data, str): data = {{ node.class_name }}.from_xml(data) if data.strip().startswith('<') else {{ node.class_name }}.model_validate_json(data)
        if data is None: raise ValueError('No data provided for update. Provide a dict, string, or kwargs.')
        data.nc_operation = operation
        elem = etree.fromstring(data.to_xml_payload())
        config_xml = etree.Element('config', nsmap={None: 'urn:ietf:params:xml:ns:netconf:base:1.0'})
        config_xml.append(wrap_in_parent_hierarchy(elem, self._path))
        return self._client.edit_config(config_xml=config_xml, target=target)

    def replace(self, data: {{ node.pydantic_module }}.{{ node.class_name }} | dict | str | None = None, *, target: str = 'candidate', **kwargs: Any) -> bool:
        return self.update(data, target=target, operation='replace', **kwargs)

    def delete(self, *, target: str = 'candidate') -> bool:
        last_ns, last_tag, _ = self._path[-1]
        elem = etree.Element("{" + last_ns + "}" + last_tag, nsmap={None: last_ns})
        elem.set('operation', 'delete')
        config_xml = etree.Element('config', nsmap={None: 'urn:ietf:params:xml:ns:netconf:base:1.0'})
        config_xml.append(wrap_in_parent_hierarchy(elem, self._path))
        return self._client.edit_config(config_xml=config_xml, target=target)
        
    {% for prop in node.properties %}
    @property
    def {{ prop.name }}(self) -> {{ prop.type_hint }}:
        path = self._path + [('{{ prop.ns }}', '{{ prop.yang_name }}', {})]
        {% if prop.item_cls %}
        from .{{ node.pydantic_module }} import {{ prop.nav_cls }}, {{ prop.item_cls }}
        return {{ prop.nav_cls }}(self._client, {{ prop.item_cls }}, path)
        {% else %}
        from .{{ node.pydantic_module }} import {{ prop.nav_cls }}
        return {{ prop.nav_cls }}(self._client, path)
        {% endif %}
    {% endfor %}

