class Data(Node):
    """Navigator for data nodes."""
    {% for prop in data_props %}
    
    @property
    def {{ prop.module }}_{{ prop.field }}(self) -> {{ prop.module }}.{% if prop.node_type == 'list' %}{% if prop.cls.endswith('Item') %}{{ prop.cls[:-4] }}{% else %}{{ prop.cls }}{% endif %}ListNode{% else %}{{ prop.cls }}Node{% endif %}:
        {% if prop.node_type == 'list' %}
        {% set base_cls = prop.cls[:-4] if prop.cls.endswith('Item') else prop.cls %}
        from .{{ prop.module }} import {{ base_cls }}ListNode, {{ prop.cls }}Node
        return {{ base_cls }}ListNode(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}", {{ prop.cls }}Node)
        {% else %}
        from .{{ prop.module }} import {{ prop.cls }}Node
        return {{ prop.cls }}Node(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}")
        {% endif %}
    {% endfor %}

class Operations(Node):
    """Navigator for RPC operations."""
    {% for prop in rpc_props %}
    
    @property
    def {{ prop.module }}_{{ prop.field }}(self) -> {{ prop.module }}.{{ prop.cls }}Node:
        from .{{ prop.module }} import {{ prop.cls }}Node
        return {{ prop.cls }}Node(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}")
    {% endfor %}
