from __future__ import annotations
from ._base import Node
from typing import TYPE_CHECKING

if TYPE_CHECKING:
{% for mod_name in module_names %}
    from . import {{ mod_name }}
{% endfor %}

class Data(Node):
    \"\"\"Navigator for data nodes.\"\"\"
    {% for prop in data_props %}
    @property
    def {{ prop.module }}_{{ prop.field }}(self) -> {{ prop.module }}.{% if prop.node_type == 'list' %}{{ prop.cls }}ListNode{% else %}{{ prop.cls }}Node{% endif %}:
        {% if prop.node_type == 'list' %}
        from .{{ prop.module }} import {{ prop.cls }}ListNode, {{ prop.cls }}ItemNode
        return {{ prop.cls }}ListNode(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}", {{ prop.cls }}ItemNode)
        {% else %}
        from .{{ prop.module }} import {{ prop.cls }}Node
        return {{ prop.cls }}Node(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}")
        {% endif %}
    {% endfor %}

class Operations(Node):
    \"\"\"Navigator for RPC operations.\"\"\"
    {% for prop in rpc_props %}
    @property
    def {{ prop.module }}_{{ prop.field }}(self) -> {{ prop.module }}.{{ prop.cls }}Node:
        from .{{ prop.module }} import {{ prop.cls }}Node
        return {{ prop.cls }}Node(self._client, f"{self._path}/{{ prop.alias }}", "{{ prop.alias }}")
    {% endfor %}
