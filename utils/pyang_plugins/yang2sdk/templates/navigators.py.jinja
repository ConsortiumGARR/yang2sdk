class {{ node.list_class_name }}Node(ListNode[{{ node.item_class_name }}Node]):
    """Navigator for list {{ node.yang_name }}"""
    
    def retrieve(self, *, content: str = "all", with_defaults: str = "report-all", depth: int | str = 2, fields: list[str] | None = None) -> list[{{ node.pydantic_module }}.{{ node.item_class_name }}]:
        from ..data_models.{{ node.pydantic_module }} import {{ node.item_class_name }}
        resp = self._retrieve(content=content, with_defaults=with_defaults, depth=depth, fields=fields)
        return [{{ node.item_class_name }}.model_validate(item) for item in resp]

    def create(self, data: list[{{ node.pydantic_module }}.{{ node.item_class_name }}]) -> None:
        payload = [x.model_dump(content="config", exclude_unset=True) for x in data]
        return self._create(payload)

    def replace(self, data: list[{{ node.pydantic_module }}.{{ node.item_class_name }}]) -> None:
        payload = [x.model_dump(content="config", exclude_unset=True) for x in data]
        return self._replace(payload)

{% elif node.node_type == 'rpc' %}
class {{ node.class_name }}Node(Node):
    """Navigator for RPC {{ node.yang_name }}"""

    def __call__(self{% if node.has_input %}, input_data: {{ node.pydantic_module }}.{{ node.class_name }}Input | dict | str | None = None, **kwargs: Any{% endif %}){% if node.has_output %} -> {{ node.pydantic_module }}.{{ node.class_name }}Output{% else %} -> None{% endif %}:
        {% if node.has_input or node.has_output %}
        from ..data_models.{{ node.pydantic_module }} import {{ node.class_name }}{% if node.has_input %}, {{ node.class_name }}Input{% endif %}{% if node.has_output %}, {{ node.class_name }}Output{% endif %}
        {% endif %}
        {% if node.has_input %}
        if input_data is None and kwargs:
            input_data = {k.replace("_", "-"): v for k, v in kwargs.items()}
        if isinstance(input_data, dict):
            input_data = {{ node.class_name }}Input.model_validate(input_data)
        elif isinstance(input_data, str):
            input_data = {{ node.class_name }}Input.model_validate_json(input_data)
        rpc_data = {{ node.class_name }}(input=input_data)
        payload = rpc_data.model_dump(mode="json", exclude_unset=True, by_alias=True)
        resp = self._client._request('POST', self._path, json=payload)
        {% else %}
        resp = self._client._request('POST', self._path)
        {% endif %}
        
        {% if node.has_output %}
        if "output" in resp:
            data = resp.get("output")
        elif "{{ node.module_yang_name }}:output" in resp:
            data = resp.get("{{ node.module_yang_name }}:output")
        else:
            data = resp
        return {{ node.class_name }}Output.model_validate(data)
        {% endif %}

